generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  SPAM
}

enum AppointmentType {
  CONSULTATION
  BRIDAL
  CUSTOM_DESIGN
  REPAIR
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  fullName      String
  phone         String?
  passwordHash  String?
  role          UserRole @default(CUSTOMER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appointments  Appointment[]
  inquiries     Inquiry[]
  reviews       Review[]
}

model Admin {
  id            String   @id @default(cuid())
  email         String   @unique
  fullName      String
  passwordHash  String
  twoFactorOn   Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  products     Product[]
}

model Collection {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String?
  coverImageUrl String?
  status        ProductStatus @default(PUBLISHED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  products      Product[]
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  shortSummary   String?
  metalType      String?
  purity         String?
  certification  String?
  priceLabel     String?
  isFeatured     Boolean       @default(false)
  status         ProductStatus @default(PUBLISHED)
  categoryId     String?
  collectionId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collection     Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  reviews        Review[]

  @@index([categoryId])
  @@index([collectionId])
  @@index([isFeatured])
}

model ProductImage {
  id            String   @id @default(cuid())
  productId     String
  imageUrl      String
  altText       String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Appointment {
  id                  String            @id @default(cuid())
  customerId          String?
  fullName            String
  email               String
  phone               String
  appointmentType     AppointmentType
  preferredDate       DateTime
  preferredTimeSlot   String
  category            String?
  occasion            String?
  notes               String?
  status              AppointmentStatus @default(PENDING)
  source              String            @default("website")
  googleCalendarEventId String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  customer            User?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  notifications       Notification[]

  @@index([email, createdAt])
  @@index([preferredDate, preferredTimeSlot])
  @@index([status])
}

model Inquiry {
  id             String     @id @default(cuid())
  customerId     String?
  fullName       String
  email          String
  phone          String?
  category       String?
  message        String
  leadStatus     LeadStatus @default(NEW)
  source         String     @default("website")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  customer       User?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([leadStatus])
}

model WhatsAppLead {
  id            String     @id @default(cuid())
  fullName      String?
  phone         String?
  message       String?
  source        String     @default("whatsapp")
  leadStatus    LeadStatus @default(NEW)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([createdAt])
  @@index([leadStatus])
}

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  fullName      String?
  isActive      Boolean  @default(true)
  source        String   @default("website")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id            String     @id @default(cuid())
  productId      String?
  customerId     String?
  reviewerName   String
  rating         Int
  title          String?
  body           String?
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  product        Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  customer       User?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([isPublished, createdAt])
}

model Testimonial {
  id            String   @id @default(cuid())
  customerName  String
  quote         String
  meta          String?
  imageUrl      String?
  isFeatured    Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isFeatured, sortOrder])
}

model StoreLocation {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  address         String
  city            String
  state           String?
  country         String   @default("India")
  postalCode      String?
  phone           String?
  email           String?
  latitude        Float?
  longitude       Float?
  mapUrl          String?
  openingHours    String?
  isFlagship      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OfferPromotion {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  description     String?
  startAt         DateTime
  endAt           DateTime
  isActive        Boolean   @default(true)
  ctaLabel        String?
  ctaUrl          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, startAt, endAt])
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String?
  coverImageUrl   String?
  isPublished     Boolean       @default(false)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([isPublished, publishedAt])
}

model Notification {
  id               String   @id @default(cuid())
  appointmentId    String?
  channel          String
  recipient        String
  message          String
  sentAt           DateTime?
  createdAt        DateTime @default(now())
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([sentAt])
}

model AnalyticsEvent {
  id             String   @id @default(cuid())
  eventName      String
  pagePath       String?
  referrer       String?
  userAgent      String?
  ipHash         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([pagePath, createdAt])
}
